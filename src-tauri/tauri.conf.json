{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mron-launcher",
  "version": "0.1.0",
  "identifier": "dev.mron.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "MRON Launcher | tg: @awalki",
        "width": 650,
        "height": 565,
        "resizable": false,
        "maximizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/mron.ico"
    ]
  }
}
